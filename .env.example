# Copy to .env or .env.local and edit. All keys are optional; defaults shown.

# Frame source: webcam (default) or tello
FRAME_SOURCE=webcam

# YOLO model + inference
MODEL_WEIGHTS=yolo11n.pt
DEVICE=auto                 # auto | cpu | mps
CONF_THRESHOLD=0.4
RED_CONF=0.5
IMGSZ=640
WARMUP_ITERS=3
DETECT_EVERY=2

# Class weights drive the grey->yellow->red spectrum
LIFE_CLASSES=person
INTEREST_CLASSES=backpack,handbag,suitcase

# Grid + sweep
GRID_ROWS=6
GRID_COLS=8
SWEEP_INTERVAL_S=2.0

# Tello-only
MIN_TAKEOFF_BATTERY=20

# Frontend (Vite)
# Optional — drop in your Mapbox public token for the geospatial overlay.
VITE_MAPBOX_TOKEN=
